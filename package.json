{
  "name": "smart-log-viewer",
  "version": "1.0.0",
  "description": "Smart ArduPilot BIN log viewer with natural language and Gemini chat",
  "private": true,
  "type": "module",
  "scripts": {
    "fetch:stitch-aerolab": "node scripts/fetch-stitch-aerolab.mjs",
    "stitch:routes": "node scripts/stitch-sync-report.mjs",
    "dev:aero-lab": "npm run dev --prefix apps/aero-lab-web",
    "build:aero-lab": "npm run build --prefix apps/aero-lab-web",
    "dev:vision-console": "npm run dev --prefix apps/vision-landing-console",
    "start:vision-console": "npm run start --prefix apps/vision-landing-console",
    "dev:mlrs-cli": "npm run dev --prefix apps/mlrs-cli-console",
    "dev:mlrs-cli:wifi": "npm run dev:wifi --prefix apps/mlrs-cli-console",
    "mlrs-bridge": "npm run bridge --prefix apps/mlrs-cli-console",
    "build:mlrs-cli": "npm run build --prefix apps/mlrs-cli-console",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev --prefix client",
    "dev:server": "npm run dev --prefix server",
    "build": "npm run build --prefix client && npm run build --prefix server",
    "start": "npm run start --prefix server"
  },
  "devDependencies": {
    "@google/stitch-sdk": "^0.0.3",
    "concurrently": "^8.2.2"
  }
}
