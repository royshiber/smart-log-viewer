GRABCAD_EMAIL=your_grabcad_email@example.com
GRABCAD_PASSWORD=your_grabcad_password
TRACEPARTS_EMAIL=your_traceparts_email@example.com
TRACEPARTS_PASSWORD=your_traceparts_password

# Browser mode: default is VISIBLE (headed) — fewer bot/WAF blocks. Set to 1 only if you want headless.
# STEP_COLLECTOR_HEADLESS=1

# If Chromium hangs on first start, use installed Google Chrome instead of Playwright's download:
# STEP_COLLECTOR_BROWSER_CHANNEL=chrome
# (or: msedge, chromium — see Playwright docs)
# STEP_COLLECTOR_USE_SYSTEM_CHROME=1

# Optional (Windows): extra folders to watch for STEP/STP/ZIP downloads, separated by semicolons.
# STEP_COLLECTOR_EXTRA_DOWNLOAD_DIRS=C:\Users\You\CustomDownloads;D:\Inbox
